# ============================================================
# ProTool Risk — .gitignore
# ============================================================

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ── Virtual Environments ──────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/

# ── Data & Model Artifacts (large files) ──────────────────
# These are generated by the pipeline — do NOT commit
data/*.parquet
data/*.npy
data/*.npz
data/*.csv

artifacts/*.pkl
artifacts/*.json
artifacts/*.csv
artifacts/xgb_model.json

demo/demo_cache.json
demo/demo_embeddings.pkl
demo/amd_benchmark.png
demo/waterfall_*.png
demo/app_errors.log

# ── HuggingFace Model Cache ──────────────────────────────
.cache/
*.bin
*.safetensors

# ── IDE & Editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Jupyter Notebooks ────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Environment & Secrets ────────────────────────────────
.env
.env.local
*.pem
*.key

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── OS Files ──────────────────────────────────────────────
Desktop.ini
ehthumbs.db
